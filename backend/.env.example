# ===== APP =====
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173

# ===== DATABASE =====
DATABASE_URL=postgres://user:password@localhost:5432/tradeedge

# ===== AUTH =====
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ===== STRIPE (payments / paywall) =====
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_MENTORING=price_xxx

# ===== EMAIL (Resend / SMTP) =====
EMAIL_FROM=hello@tradeedge.sk
RESEND_API_KEY=re_xxx

# ===== VIDEO (Mux / Bunny / Cloudflare Stream) =====
VIDEO_PROVIDER=mux
MUX_TOKEN_ID=xxx
MUX_TOKEN_SECRET=xxx

# ===== NOTION SYNC (Trade Journal) =====
# 1) Create an internal integration: https://www.notion.so/my-integrations
# 2) Open the Trading Journal database → ... → Connections → add the integration
# 3) Copy the integration secret here:
NOTION_TOKEN=secret_xxx
# Trading Journal database ID (UUID with dashes):
NOTION_TRADES_DB_ID=00000000-0000-0000-0000-000000000000
